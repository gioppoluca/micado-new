{
  "name": "backend",
  "version": "0.0.1",
  "description": "backend",
  "keywords": [
    "loopback-application",
    "loopback"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": "20 || 22 || 24"
  },
  "scripts": {
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "lint": "npm run eslint && npm run prettier:check",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "prettier:cli": "lb-prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "npm run prettier:cli -- -l",
    "prettier:fix": "npm run prettier:cli -- --write",
    "eslint": "lb-eslint --report-unused-disable-directives .",
    "eslint:fix": "npm run eslint -- --fix",
    "pretest": "npm run rebuild",
    "test": "lb-mocha --allow-console-logs \"dist/__tests__\"",
    "posttest": "npm run lint",
    "test:dev": "lb-mocha --allow-console-logs dist/__tests__/**/*.js && npm run posttest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "docker:build": "docker build -t backend .",
    "docker:run": "docker run -p 3000:3000 -d backend",
    "premigrate": "npm run build",
    "migrate": "node ./dist/migrate",
    "preopenapi-spec": "npm run build",
    "openapi-spec": "node ./dist/openapi-spec",
    "prestart": "npm run rebuild",
    "start": "node -r source-map-support/register .",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache",
    "watch:ts": "lb-tsc --watch",
    "watch:node": "nodemon -L --watch dist --ext js --delay 1 --exec \"node -r source-map-support/register dist/index.js\"",
    "dev": "npm run build && concurrently -k \"npm:watch:ts\" \"npm:watch:node\"",
    "rebuild": "npm run clean && npm run build"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "",
  "license": "",
  "files": [
    "README.md",
    "dist",
    "src",
    "!*/__tests__"
  ],
  "dependencies": {
    "@dbos-inc/dbos-sdk": "^4.10.15",
    "@loopback/authentication": "^12.0.11",
    "@loopback/authorization": "^0.16.10",
    "@loopback/boot": "^8.0.10",
    "@loopback/core": "^7.0.9",
    "@loopback/logging": "^0.13.10",
    "@loopback/repository": "^8.0.9",
    "@loopback/rest": "^15.0.10",
    "@loopback/rest-explorer": "^8.0.10",
    "@loopback/security": "^0.12.10",
    "@loopback/service-proxy": "^8.0.9",
    "@types/uuid": "^10.0.0",
    "jose": "^6.1.3",
    "loopback-connector-postgresql": "^8.0.6",
    "tslib": "^2.0.0",
    "undici": "^7.22.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@loopback/build": "^12.0.9",
    "@loopback/eslint-config": "^16.0.1",
    "@loopback/testlab": "^8.0.9",
    "@playwright/test": "^1.58.2",
    "@types/node": "^16.18.126",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "nodemon": "^3.1.0",
    "source-map-support": "^0.5.21",
    "typescript": "~5.2.2"
  }
}
