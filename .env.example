BASE_DOMAIN=localhost
TRAEFIK_EMAIL=admin@example.com

# --- PostgreSQL bootstrap ---
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASS=postgres
POSTGRES_DB=micado

# --- Keycloak database and public issuer defaults ---
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak
KEYCLOAK_ISSUER_BASE=http://keycloak.localhost
KEYCLOAK_ALLOWED_REALMS=migrants
KEYCLOAK_EXPECTED_AUDIENCE=micado-backend

# --- Application database ---
APP_DB=micado
APP_DB_USER=micado
MICADO_APP_PASSWORD=micado-app-password

# --- Weblate ---
WEBLATE_DB=weblate
WEBLATE_DB_USER=weblate
WEBLATE_DB_PASSWORD=weblate
WEBLATE_ADMIN_PASSWORD=weblate-admin
WEBLATE_WEBHOOK_URL=http://backend:3000/api/webhooks/weblate/translation-complete
MICADO_TARGET_LANGS="it,fr,ar,de,sq,mk"
MICADO_SOURCE_LANG=en
MICADO_CATEGORIES=categories,event,information,glossary

# --- Keycloak bootstrap admin ---
KC_BOOTSTRAP_ADMIN_USERNAME=kcadmin
KC_BOOTSTRAP_ADMIN_PASSWORD=kcadmin

# --- Backend HTTP/CORS ---
BACKEND_PORT=3000
CORS_ORIGIN=http://migrants.${BASE_DOMAIN},http://pa.${BASE_DOMAIN},http://ngo.${BASE_DOMAIN}

# --- Backend Keycloak multi-realm verification ---
BACKEND_KEYCLOAK_ISSUER_BASE=http://auth.${BASE_DOMAIN}
BACKEND_KEYCLOAK_INTERNAL_BASE=http://keycloak:8080
BACKEND_KEYCLOAK_ALLOWED_REALMS=migrants,pa_frontoffice,ngo_frontoffice
BACKEND_KEYCLOAK_EXPECTED_AUDIENCE=micado-backend

# --- Gitea (used by Weblate) ---
GITEA_DB=gitea
GITEA_DB_USER=gitea
GITEA_DB_PASSWORD=gitea

GITEA_ADMIN_USER=gitea-admin
GITEA_ADMIN_PASSWORD=gitea-admin
GITEA_ADMIN_EMAIL=admin@example.com

GITEA_WEBLATE_USER=weblate-bot
GITEA_WEBLATE_PASSWORD=weblate-bot
GITEA_WEBLATE_EMAIL=weblate-bot@example.com

GITEA_TRANSLATIONS_REPO=backend-translations

# --- DBOS workflow schema/user ---
DBOS_DB_SCHEMA=dbos
DBOS_DB_USER=dbos

# --- Umami analytics ---
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=change-me-strong
UMAMI_APP_SECRET=change-me-long-random-secret
UMAMI_ADMIN_USERNAME=admin
UMAMI_ADMIN_PASSWORD=umami

UMAMI_MIGRANTS_WEBSITE_ID=11111111-1111-4111-8111-111111111111
UMAMI_PA_WEBSITE_ID=22222222-2222-4222-8222-222222222222
UMAMI_NGO_WEBSITE_ID=33333333-3333-4333-8333-333333333333

UMAMI_MIGRANTS_NAME=Migrants
UMAMI_PA_NAME=PA
UMAMI_NGO_NAME=NGO

# --- Backend dummy auth (dev only) ---
# AUTH_DISABLE_KEYCLOAK=true
# AUTH_DUMMY_ROLES=pa_admin
# AUTH_DUMMY_USERNAME=dev.user

# --- Logging ---
LOG_LEVEL=info
FRONTEND_LOG_LEVEL=info

# --- Frontend development flags ---
VITE_API_MOCK=true
